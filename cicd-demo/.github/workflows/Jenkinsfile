pipeline {
    agent any

    tools {
        // This must match the name in Jenkins -> Manage Jenkins -> Global Tool Configuration
        maven 'Maven3'
    }

    stages {
        stage('CHECKOUT') {
            steps {
                // Fixed: Replaced the placeholder with your actual repository link
                git 'https://github.com/Shreya-Rajashekara12/cicd-demo.git'
            }
        }

        stage('Build') {
            steps {
                // dir('cicd-demo') should match the folder name inside your GitHub repo
                dir('cicd-demo') {
                    bat 'mvn clean install'
                }
            }
        }

        stage('Test') {
            steps {
                dir('cicd-demo') {
                    bat 'mvn test'
                }
            }
        }
    }
}
